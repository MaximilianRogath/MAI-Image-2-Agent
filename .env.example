# ============================================================
#  .env.example  —  Environment variable template
#  Copy to .env and fill in your values
#
#  Authentication: all Azure resources use keyless auth
#  via DefaultAzureCredential. Run 'az login' before starting
#  the agent. No API keys required.
# ============================================================

# --- Microsoft Foundry (Agent Framework) --------------------
# Project endpoint from the Azure AI Foundry portal (Overview page)
AZURE_FOUNDRY_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project

# Model deployment name for the agent (prompt enhancement)
AZURE_FOUNDRY_MODEL=gpt-4o

# --- MAI-Image-2 --------------------------------------------
# Base endpoint of your Azure AI Foundry resource (without /api/projects/...)
AZURE_MAI_ENDPOINT=https://your-resource.services.ai.azure.com

# Deployment name of your MAI-Image-2 deployment in Foundry
AZURE_MAI_IMAGE_DEPLOYMENT=mai-image-2

# --- Output -------------------------------------------------
# Directory where generated images are saved (default: output)
IMAGE_OUTPUT_DIR=output
